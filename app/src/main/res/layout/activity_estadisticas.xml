<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F3FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Volver"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estadísticas"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/txtTotalTareas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tareas: 0"
            android:textSize="20sp"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/txtCompletadas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completadas: 0"
            android:textSize="20sp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/txtPomodoros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pomodoros: 0"
            android:textSize="20sp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/txtPendientes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendientes: 0"
            android:textSize="20sp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/txtTiempo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiempo: 0h"
            android:textSize="20sp"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</ScrollView>