<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:strokeColor="#D6CCE8"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título"
            android:textColor="#3E3550"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Descripción"
            android:textColor="#6B6475"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/txtCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Categoría"
            android:textColor="#7A7286"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/txtPomodoros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="0/5"
            android:textColor="#6A4FB3"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnPomodoro"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:text="▶ Iniciar Temporizador"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="#6A4FB3"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>